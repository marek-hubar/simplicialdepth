## Generated from src/Makevars.win.in by configure.win
## This is a fallback for Windows binary installations and source builds
## where R_HOME or configure.win might not be available.
## 
## On Windows with configure.win available, this file will be regenerated
## with actual RcppParallel flags detected at build time.

## Compiler optimization and warning flags: -O3 for performance, -Wall for quality
## Link-Time Optimization (-flto) enabled for 5-15% additional performance
PKG_CXXFLAGS = -O3 -Wall -flto @PKG_CXXFLAGS@

## TBB linker flags (will be replaced by configure.win if available)
## Fallback: empty string - Windows R will handle RcppParallel linking via DESCRIPTION
PKG_LIBS = @PKG_LIBS@ -flto
